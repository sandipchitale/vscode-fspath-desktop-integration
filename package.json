{
    "name": "vscode-fspath-desktop-integration",
    "displayName": "File path Desktop Integration",
    "icon": "images/icon.png",
    "description": "VS Code extention for file path Desktop Integration. Copy Path, Reveal in file Explorer, Run external terminal, Run built in terminal.",
    "version": "1.0.4",
    "publisher": "sandipchitale",
    "author": {
        "name": "Sandip Chitale"
    },
    "maintainers": [
        "Sandip Chitale <sandipchitale@gmail.com>"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/sandipchitale/vscode-fspath-desktop-integration"
    },
    "engines": {
        "vscode": "^1.30.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:vscode-fspath-desktop-integration.explorer.copyName",
        "onCommand:vscode-fspath-desktop-integration.explorer.copy",
        "onCommand:vscode-fspath-desktop-integration.editor.copyPath",
        "onCommand:vscode-fspath-desktop-integration.editor.copyRelativePath",
        "onCommand:vscode-fspath-desktop-integration.editor.copy",
        "onCommand:vscode-fspath-desktop-integration.editor-text.copy",
        "onCommand:vscode-fspath-desktop-integration.explorer.explorer",
        "onCommand:vscode-fspath-desktop-integration.editor.explorer",
        "onCommand:vscode-fspath-desktop-integration.editor-text.explorer",
        "onCommand:vscode-fspath-desktop-integration.explorer.terminal",
        "onCommand:vscode-fspath-desktop-integration.editor.terminal",
        "onCommand:vscode-fspath-desktop-integration.editor-text.terminal",
        "onCommand:vscode-fspath-desktop-integration.explorer.external-terminal",
        "onCommand:vscode-fspath-desktop-integration.editor.external-terminal",
        "onCommand:vscode-fspath-desktop-integration.editor-text.external-terminal"
    ],
    "main": "./out/extension",
    "contributes": {
        "commands": [
            {
                "command": "vscode-fspath-desktop-integration.explorer.copyName",
                "title": "Copy Name"
            },
            {
                "command": "vscode-fspath-desktop-integration.explorer.copy",
                "title": "Copy path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.explorer.explorer",
                "title": "Reveal path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.explorer.terminal",
                "title": "Terminal at path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.explorer.external-terminal",
                "title": "External terminal at path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor.copyPath",
                "title": "Copy path"
            },
            {
                "command": "vscode-fspath-desktop-integration.editor.copyRelativePath",
                "title": "Copy relative path"
            },
            {
                "command": "vscode-fspath-desktop-integration.editor.copy",
                "title": "Copy path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor.explorer",
                "title": "Reveal path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor.terminal",
                "title": "Terminal at path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor.external-terminal",
                "title": "External terminal at path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor-title.copy",
                "title": "Copy path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor-title.explorer",
                "title": "Reveal path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor-title.terminal",
                "title": "Terminal at path(s)..."
            },
            {
                "command": "vscode-fspath-desktop-integration.editor-title.external-terminal",
                "title": "External terminal at path(s)..."
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "vscode-fspath-desktop-integration.explorer.copyName",
                    "group": "6_copypath@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.explorer.copy",
                    "group": "6_copypath@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.explorer.explorer",
                    "group": "6_copypath@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.explorer.terminal",
                    "group": "6_copypath@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.explorer.external-terminal",
                    "group": "6_copypath@100",
                    "when": "resourceScheme == file"
                }
            ],
            "editor/context": [
                {
                    "command": "vscode-fspath-desktop-integration.editor.copyPath",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor.copyRelativePath",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor.copy",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor.explorer",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor.terminal",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor.external-terminal",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                }
            ],
            "editor/title/context": [
                {
                    "command": "vscode-fspath-desktop-integration.editor-title.copy",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor-title.explorer",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor-title.terminal",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                },
                {
                    "command": "vscode-fspath-desktop-integration.editor-title.external-terminal",
                    "group": "1_cutcopypaste@100",
                    "when": "resourceScheme == file"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "postinstall": "node ./node_modules/vscode/bin/install",
        "test": "npm run compile && node ./node_modules/vscode/bin/test"
    },
    "devDependencies": {
        "typescript": "^2.6.1",
        "vscode": "^1.1.6",
        "@types/node": "^7.0.43",
        "@types/mocha": "^2.2.42"
    }
}
